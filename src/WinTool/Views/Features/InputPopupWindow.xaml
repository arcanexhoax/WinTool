<views:FluentWindow x:Class="WinTool.Views.Features.InputPopupWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:views="clr-namespace:WinTool.Views"
                    xmlns:local="clr-namespace:WinTool.Views.Features"
                    xmlns:vm="clr-namespace:WinTool.ViewModels.Features"
                    mc:Ignorable="d"
                    d:DataContext="{d:DesignInstance Type=vm:InputPopupViewModel}"
                    ResizeMode="NoResize"
                    Focusable="False"
                    ShowInTaskbar="False"
                    SizeToContent="Width"
                    Height="40">
    <Border Background="{DynamicResource AcrylicLayoutBrush}" 
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid>
            <ItemsControl x:Name="LanguageItemsControl" 
                          ItemsSource="{Binding AllLanguages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="{x:Static local:InputPopupWindow.SelectionItemWidth}">
                            <TextBlock Text="{Binding Name}"
                                       Padding="8 16"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid x:Name="SelectionOverlay"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Stretch"
                  IsHitTestVisible="False">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="SelectionTranslate" />
                </Grid.RenderTransform>

                <Border CornerRadius="6"
                        BorderThickness="1"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" />

                <Border CornerRadius="2"
                        Width="20"
                        Height="3"
                        VerticalAlignment="Bottom"
                        Margin="0 0 0 3"
                        Background="{DynamicResource AccentFillColorTertiaryBrush}"
                        RenderTransformOrigin="0.5 0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="AccentScale" />
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Grid>
    </Border>
</views:FluentWindow>
