<Grid x:Class="WinTool.Views.ContentDialogHost"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Visibility="Collapsed">
    <Grid.Resources>
        <Storyboard x:Key="OpenDialogStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SmokeLayer"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.083"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogScale"
                                           Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1.05" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.250"
                                      KeySpline="0.1,0.9 0.2,1.0"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogScale"
                                           Storyboard.TargetProperty="ScaleY">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1.05" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.250"
                                      KeySpline="0.1,0.9 0.2,1.0"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogContainer"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.083"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="CloseDialogStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SmokeLayer"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.083"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogScale"
                                           Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.167"
                                      KeySpline="0.1,0.9 0.2,1.0"
                                      Value="1.05" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogScale"
                                           Storyboard.TargetProperty="ScaleY">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.167"
                                      KeySpline="0.1,0.9 0.2,1.0"
                                      Value="1.05" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DialogContainer"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0"
                                        Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.083"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Grid.Resources>

    <Border x:Name="SmokeLayer"
            Background="{DynamicResource SmokeFillColorDefaultBrush}"
            Opacity="0" />

    <Border x:Name="DialogContainer"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="DialogScale"
                            ScaleX="1.05"
                            ScaleY="1.05" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32"
                              ShadowDepth="2"
                              Direction="270"
                              Opacity="0.6"
                              Color="Black" />
        </Border.Effect>

        <ContentPresenter x:Name="DialogPresenter" />
    </Border>
</Grid>
