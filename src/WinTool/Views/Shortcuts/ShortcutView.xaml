<UserControl x:Class="WinTool.Views.Shortcuts.ShortcutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WinTool.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:c="clr-namespace:Hoax.WpfConverters;assembly=Hoax.WpfConverters"
             xmlns:vm="clr-namespace:WinTool.ViewModels.Shortcuts"
             xmlns:p="clr-namespace:WinTool.Properties"
             d:DataContext="{d:DesignInstance Type=vm:ShortcutViewModel}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <c:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <c:ObjectComparisonConverter x:Key="IsNullConv" Operation="IsNull" Then="{StaticResource BoolToVisConverter}" />
        <c:ObjectComparisonConverter x:Key="IsNotNullConv" Operation="IsNotNull" Then="{StaticResource BoolToVisConverter}" />
    </UserControl.Resources>

    <Grid Height="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding Icon}"
                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                   FontSize="18"
                   Margin="0 0 20 0" />

        <TextBlock Text="{Binding Description}"
                   ToolTip="{Binding Description}"
                   TextTrimming="CharacterEllipsis"
                   Grid.Column="1" />

        <Border Grid.Column="3">
            <StackPanel Orientation="Horizontal"
                        Background="Transparent"
                        HorizontalAlignment="Right">
                <Button x:Name="EditButton"
                        Focusable="False"
                        Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}, Converter={StaticResource BoolToVisConverter}}"
                        Command="{Binding EditShortcutCommand}"
                        Margin="0 0 8 0">
                    <TextBlock Text="{StaticResource Icon.Edit}"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="12" />
                </Button>

                <ctrl:Shortcut FontSize="14"
                               Visibility="{Binding Shortcut, Converter={StaticResource IsNotNullConv}}"
                               VerticalAlignment="Center"
                               Value="{Binding Shortcut}" />

                <TextBlock Text="{x:Static p:Resources.NotSpecified}"
                           Foreground="{StaticResource SystemFillColorCautionBrush}"
                           Visibility="{Binding Shortcut, Converter={StaticResource IsNullConv}}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
