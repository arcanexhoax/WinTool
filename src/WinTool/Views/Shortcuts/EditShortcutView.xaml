<view:ContentDialogView x:Class="WinTool.Views.Shortcuts.EditShortcutView"
                        x:TypeArguments="model:EditShortcutInput,gki:Shortcut"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:c="clr-namespace:Hoax.WpfConverters;assembly=Hoax.WpfConverters"
                        xmlns:ctrl="clr-namespace:WinTool.UI.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:gki="clr-namespace:GlobalKeyInterceptor;assembly=GlobalKeyInterceptor"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:model="clr-namespace:WinTool.Models"
                        xmlns:p="clr-namespace:WinTool.Properties"
                        xmlns:view="clr-namespace:WinTool.Views"
                        xmlns:vm="clr-namespace:WinTool.ViewModels.Shortcuts"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:EditShortcutViewModel}"
                        Width="500">
    <UserControl.Resources>
        <c:BoolToVisibilityConverter x:Key="boolToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource EmptyBackdropBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="80" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    CornerRadius="8 8 0 0"
                    Padding="26">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="{x:Static p:Resources.EnterNewShortcut}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{x:Static p:Resources.EditShortcutTip}"
                               Margin="0 10 0 0" />

                    <Border Padding="0 36 0 0">
                        <StackPanel>
                            <ctrl:Shortcut Value="{Binding Shortcut}"
                                           HorizontalAlignment="Center"
                                           FontSize="30" />

                            <TextBlock Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       Text="{Binding ErrorText}"
                                       Visibility="{Binding IsErrorShown, Converter={StaticResource boolToVis}}"
                                       Margin="0 16 0 0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Padding="26 0"
                    Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding SaveCommand}"
                            Content="{x:Static p:Resources.Save}"
                            HorizontalAlignment="Stretch" />
                    <Button Command="{Binding CancelCommand}"
                            Content="{x:Static p:Resources.Cancel}"
                            HorizontalAlignment="Stretch"
                            Grid.Column="2" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</view:ContentDialogView>
