<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:WinTool.UI.Controls">
    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Grid x:Name="RootGrid"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ContentPresenter x:Name="LeftStateContentPresenter"
                                          Margin="0 0 10 0"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"
                                          Content="{TemplateBinding CurrentContent}"
                                          RecognizesAccessKey="True"
                                          TextElement.FontSize="14"
                                          TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <Grid x:Name="SwitchRoot"
                              Width="40"
                              Height="20"
                              Grid.Column="1">
                            <Border x:Name="OuterBorder"
                                    Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10" />

                            <Ellipse x:Name="SwitchKnob"
                                     Width="12"
                                     Height="12"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource TextFillColorSecondaryBrush}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="KnobTranslate" X="-10" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>

                        <ContentPresenter x:Name="RightStateContentPresenter"
                                          Margin="10 0 0 0"
                                          VerticalAlignment="Center"
                                          Grid.Column="2"
                                          Visibility="Collapsed"
                                          Content="{TemplateBinding CurrentContent}"
                                          RecognizesAccessKey="True"
                                          TextElement.FontSize="14"
                                          TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowStateContent" Value="True" />
                                <Condition Property="StateContentPosition" Value="{x:Static controls:ToggleSwitchStateContentPosition.Left}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LeftStateContentPresenter" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowStateContent" Value="True" />
                                <Condition Property="StateContentPosition" Value="{x:Static controls:ToggleSwitchStateContentPosition.Right}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RightStateContentPresenter" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!-- Checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="10"
                                                         Duration="0:0:0.167">
                                            <DoubleAnimation.EasingFunction>
                                                <CircleEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="-10"
                                                         Duration="0:0:0.167">
                                            <DoubleAnimation.EasingFunction>
                                                <CircleEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Hover (unchecked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ControlAltFillColorTertiaryBrush}" />
                            <Setter TargetName="SwitchKnob" Property="Width" Value="14" />
                            <Setter TargetName="SwitchKnob" Property="Height" Value="14" />
                        </MultiTrigger>

                        <!-- Hover (checked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            <Setter TargetName="SwitchKnob" Property="Width" Value="14" />
                            <Setter TargetName="SwitchKnob" Property="Height" Value="14" />
                        </MultiTrigger>

                        <!-- Disabled (unchecked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ControlStrongFillColorDisabledBrush}" />
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="{DynamicResource ControlStrongFillColorDisabledBrush}" />
                            <Setter TargetName="LeftStateContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="RightStateContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </MultiTrigger>

                        <!-- Disabled (checked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ControlStrongFillColorDisabledBrush}" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ControlStrongFillColorDisabledBrush}" />
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="{DynamicResource TextOnAccentFillColorDisabledBrush}" />
                            <Setter TargetName="LeftStateContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="RightStateContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
